{
  "contractExpectations": {
    "errorResponse": ["success", "errorCode", "message", "errors", "path", "timestamp"],
    "successResponse": ["success", "message", "data", "timestamp"],
    "productResponseObject": ["id", "name","category", "manufacturer", "price", "salePrice", "currencyCode", "sku",
                              "quantityInStock", "expectedAvailabilityDate", "attributes", "imageUrl", "status", "version"]
  },
  "validPayload": {
    "name": "Kettle",
    "category": "Kitchen",
    "manufacturer": "Deco",
    "price": 11.5,
    "costPrice": 10.0,
    "salePrice": 11.0,
    "currencyCode": "USD",
    "sku": "KT-WT-1234",
    "quantityInStock": 0,
    "lowStockThreshold": 1,
    "status": "IN_STOCK",
    "expectedAvailabilityDate": "2026-12-31T23:59:59",
    "imageUrl": "https://example.com/products/blanket.jpg",
    "attributes": {
      "color": "White",
      "pattern": "Dragon",
      "collection": "Big City",
      "tags": ["home", "soft", "lazy"]
    },
    "createdBy": "Alex Brown"
  },
  "userEndpoints": {"base": "api/v1/products"},
