    "productNameScenarios": {
      "positive": [
        {"testName": "valid value", "payload": { "value": "alex" },"expected": { "status": 200, "message": "Success" }},
        {"testName": "leading and trailing spaces", "payload": { "value": "  alex  " },"expected": { "status": 200, "message": "Success" }},
        {"testName": "boundary: 2 chars","payload": { "value": "al" }, "expected": { "status": 200, "message": "Success" }},
        {"testName": "boundary: 150 chars","payload": {"value": "alexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissoss"}, "expected": { "status": 200, "message": "Success" }},
        {"testName": "using capital letters", "payload": { "value": "Alex" }, "expected": { "status": 200, "message": "Success" }},
        {"testName": "with spaces", "payload": { "value": "Alex Manner Jr" }, "expected": { "status": 200, "message": "Success" }},
        {"testName": "with dot", "payload": { "value": "Alex Jr." },"expected": { "status": 200, "message": "Success" }},
        {"testName": "with hyphen", "payload": { "value": "Alex-Morales" }, "expected": { "status": 200, "message": "Success" }}
      ],
      "negative": [
        {"testName": "empty string", "payload": { "value": "" }, "expected": { "status": 400, "error": "Product name must not be blank" }},
        {"testName": "null value", "payload": { "value": null }, "expected": { "status": 400, "error": "Product name must not be blank" }},
        {"testName": "whitespaces only", "payload": { "value": "          " }, "expected": { "status": 400, "error": "Product name must not be blank" }},
        {"testName": "numeric input", "payload": { "value": "Alex123" }, "expected": { "status": 400, "error": "Product name has unsupported characters" }},
        {"testName": "with comma", "payload": { "value": "Alex, Jr" }, "expected": { "status": 400, "error": "Product name has unsupported characters" }},
        {"testName": "with special characters", "payload": { "value": "Alex/ Jr" }, "expected": { "status": 400, "error": "Product name has unsupported characters" }},
        {"testName": "input lenght 1 character", "payload": { "value": "A" }, "expected": { "status": 400, "error": "Product name must be between 2 and 150 characters" }},
        {"testName": "input lenght 151 character", "payload": {"value": "alexissossalexissossalexissossalexissossalexissossalexissossalexXissossalexissossalexissossalexissossalexissossalexissossalexissossalexissossalexissoss"}, "expected": { "status": 400, "error": "Product name must be between 2 and 150 characters" }}
      ]
